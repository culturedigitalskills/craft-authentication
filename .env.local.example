# App
PORT=20100
NODE_ENV=development

# Database (local dev)
POSTGRES_USER=crafter_admin
POSTGRES_PASSWORD=CHANGE_TO_DATABASE_PASSWORD
POSTGRES_DB=crafts_dev
POSTGRES_PORT=20101
DATABASE_URL_APP=postgresql://crafter_admin:CHANGE_TO_DATABASE_PASSWORD@localhost:20101/crafts_dev
DATABASE_URL=postgresql://crafter_admin:CHANGE_TO_DATABASE_PASSWORD@localhost:20101/crafts_dev
# Note: DATABASE_URL is used by Prisma CLI commands (pnpm db:migrate, db:push, db:studio)

# Garage S3 Storage (local dev)
# Generate real secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# After running `pnpm docker:up`, run `pnpm garage:init` to set up Garage
GARAGE_RPC_SECRET=CHANGE_TO_RANDOM_SECRET_32_CHARS
S3_ACCESS_KEY=CHANGE_TO_ACCESS_KEY_FROM_INIT_SCRIPT
S3_SECRET_KEY=CHANGE_TO_SECRET_KEY_FROM_INIT_SCRIPT
S3_PORT=20102
GARAGE_ADMIN_PORT=20103
S3_BUCKET=crafts-dev-bucket
S3_REGION=garage
S3_ENDPOINT=http://localhost:20102

# Auth.js
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=CHANGE_TO_RANDOM_SECRET_32_CHARS
AUTH_URL=http://localhost:20100

# Google OAuth
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=CHANGE_TO_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=CHANGE_TO_GOOGLE_CLIENT_SECRET

# Verifiable Credentials — RSA-2048 signing keys
# Generate once: node -e "const {generateKeyPairSync}=require('crypto');const {privateKey,publicKey}=generateKeyPairSync('rsa',{modulusLength:2048,publicKeyEncoding:{type:'spki',format:'pem'},privateKeyEncoding:{type:'pkcs8',format:'pem'}});console.log('VC_PRIVATE_KEY='+JSON.stringify(privateKey));console.log('VC_PUBLIC_KEY='+JSON.stringify(publicKey));"

# Default (recommended): use file-based secrets mounted by docker-compose.
VC_PRIVATE_KEY_PATH=./secrets/vc_private_key.pem
VC_PUBLIC_KEY_PATH=./secrets/vc_public_key.pem

# Less secure fallback: inline PEM values in environment variables.
# Use only if file-based mounts are not available.
# VC_PRIVATE_KEY="CHANGE_TO_GENERATED_PRIVATE_KEY_PEM"
# VC_PUBLIC_KEY="CHANGE_TO_GENERATED_PUBLIC_KEY_PEM"

# Optional: if set, you can call GET /api/vc/signing-test with x-vc-test-token in any environment.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VC_TEST_TOKEN=CHANGE_TO_RANDOM_TEST_TOKEN

# Vault & KMS Settings
# Run `node scripts/generate-kms-keys.mjs` once to generate all three values below automatically.

# RSA-4096 key pair for MockLocalKMS (file-based; paths relative to project root)
KMS_PRIVATE_KEY_PATH=./secrets/kms_private_key.pem
KMS_PUBLIC_KEY_PATH=./secrets/kms_public_key.pem

# 256-bit symmetric key used by MockLocalKMS to wrap MasterVaultKeys (AES-256-GCM).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LOCAL_MASTER_KEY=CHANGE_TO_64_CHAR_HEX_STRING

# HMAC key used to hash WebAuthn credential IDs for user privacy protection.
# Required — startup will fail if neither VAULT_SERVER_SECRET nor AUTH_SECRET is set.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
VAULT_SERVER_SECRET=CHANGE_TO_RANDOM_SECRET_32_CHARS

# Content Credentials Root Key & Certificate (for C2PA support)
C2PA_ROOT_KEY_PATH=./secrets/c2pa_root_key.pem
C2PA_ROOT_CERT_PATH=./secrets/c2pa_root_cert.pem

# C2PA Trust List (for signature verification)
C2PA_TRUST_LIST_PATH=./secrets/c2pa-trust-list.pem

