# App
PORT=3000
NODE_ENV=production

# Database (containers/prod)
POSTGRES_USER=crafter_admin
POSTGRES_PASSWORD=CHANGE_TO_DATABASE_PASSWORD
POSTGRES_DB=crafts
POSTGRES_PORT=5432
DATABASE_URL_APP=postgresql://crafter_admin:CHANGE_TO_DATABASE_PASSWORD@postgres:5432/crafts
DATABASE_URL=postgresql://crafter_admin:CHANGE_TO_DATABASE_PASSWORD@localhost:5432/crafts
# Note: DATABASE_URL_APP is used by the app container; DATABASE_URL is used by Prisma CLI (prod:db:migrate, etc.)

# Garage S3 Storage (containers/prod)
# Generate real secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GARAGE_RPC_SECRET=CHANGE_TO_RANDOM_SECRET_32_CHARS
GARAGE_ADMIN_TOKEN=CHANGE_TO_RANDOM_ADMIN_TOKEN
S3_ACCESS_KEY=auto-generated
S3_SECRET_KEY=auto-generated
S3_PORT=3900
GARAGE_ADMIN_PORT=3903
S3_BUCKET=crafts-bucket
S3_REGION=garage
S3_ENDPOINT=http://garage:3900

# Auth.js
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=CHANGE_TO_RANDOM_SECRET_32_CHARS
AUTH_URL=https://yourdomain.com

# Google OAuth
GOOGLE_CLIENT_ID=CHANGE_TO_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=CHANGE_TO_GOOGLE_CLIENT_SECRET

# Verifiable Credentials — RSA-2048 signing keys
# Generate once: node -e "const {generateKeyPairSync}=require('crypto');const {privateKey,publicKey}=generateKeyPairSync('rsa',{modulusLength:2048,publicKeyEncoding:{type:'spki',format:'pem'},privateKeyEncoding:{type:'pkcs8',format:'pem'}});console.log('VC_PRIVATE_KEY='+JSON.stringify(privateKey));console.log('VC_PUBLIC_KEY='+JSON.stringify(publicKey));"

# Default (recommended): use file-based secrets mounted by docker-compose.
VC_PRIVATE_KEY_PATH=/run/secrets/vc_private_key.pem
VC_PUBLIC_KEY_PATH=/run/secrets/vc_public_key.pem

# Less secure fallback: inline PEM values in environment variables.
# Use only if file-based mounts are not available.
# VC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# VC_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"

# Optional: protects GET /api/vc/signing-test in production.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VC_TEST_TOKEN=CHANGE_TO_RANDOM_TEST_TOKEN

# Vault & KMS Settings
# In production, replace MockLocalKMS with a real KMS (OpenBao, Scaleway Key Manager,
# OVHcloud KMS, HashiCorp Vault). The file-based paths below are for MockLocalKMS only.
#
# RSA-4096 key pair for MockLocalKMS — mounted via docker-compose secrets volume.
# Generate with: node scripts/generate-kms-keys.mjs (on first deploy; copies to ./secrets/)
KMS_PRIVATE_KEY_PATH=/run/secrets/kms_private_key.pem
KMS_PUBLIC_KEY_PATH=/run/secrets/kms_public_key.pem

# 256-bit symmetric key used by MockLocalKMS (AES-256-GCM wrapping of MasterVaultKeys).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LOCAL_MASTER_KEY=CHANGE_TO_64_CHAR_HEX_STRING

# HMAC key used to hash WebAuthn credential IDs for user privacy protection.
# Required — startup will fail if neither VAULT_SERVER_SECRET nor AUTH_SECRET is set.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
VAULT_SERVER_SECRET=CHANGE_TO_RANDOM_SECRET_32_CHARS

# Content Credentials Root Key & Certificate (for C2PA support)
C2PA_ROOT_KEY_PATH=./secrets/c2pa_root_key.pem
C2PA_ROOT_CERT_PATH=./secrets/c2pa_root_cert.pem

# C2PA Trust List (for signature verification)
C2PA_TRUST_LIST_PATH=./secrets/c2pa-trust-list.pem