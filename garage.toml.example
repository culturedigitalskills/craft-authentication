metadata_dir = "/meta"
data_dir = "/data"

replication_factor = 1

rpc_bind_addr = "[::]:3901"
rpc_public_addr = "127.0.0.1:3901"
rpc_secret_file = "/run/secrets/rpc_secret"

[s3_api]
s3_region = "garage"
api_bind_addr = "[::]:3900"

[s3_web]
bind_addr = "[::]:3902"
root_domain = ".s3.garage.localhost"

[admin]
api_bind_addr = "[::]:3903"

# Uncomment and set this to enable the Admin HTTP API:
# admin_token = "your-secret-token-here"
