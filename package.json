{
    "name": "craft-authentication",
    "version": "0.13.0",
    "private": true,
    "packageManager": "pnpm@11.5.2",
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "dev": "node scripts/generate-build-info.js && dotenv -e .env.local -- next dev",
        "build-info": "node scripts/generate-build-info.js",
        "docker:up": "docker compose -f docker-compose.dev.yml --env-file .env.local up -d",
        "docker:down": "docker compose -f docker-compose.dev.yml --env-file .env.local down",
        "garage:init": "node scripts/init-garage.js .env.local craft-authentication",
        "db:studio": "dotenv -e .env.local -- prisma studio",
        "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
        "db:rollback": "dotenv -e .env.local -- prisma migrate deploy",
        "db:push": "dotenv -e .env.local -- prisma db push",
        "build": "dotenv -e .env.production -- next build",
        "start": "dotenv -e .env.production -- next start",
        "lint": "eslint .",
        "lint:fix": "pnpm lint --fix",
        "db:generate": "dotenv -e .env.local -- prisma generate",
        "docker:build": "node scripts/generate-build-info.js && docker compose --env-file .env.production build app --no-cache",
        "prod:docker:up": "docker compose --env-file .env.production up -d",
        "prod:docker:down": "docker compose --env-file .env.production down",
        "prod:docker:logs": "docker compose --env-file .env.production logs -f app",
        "prod:db:push": "dotenv -e .env.production -- prisma db push",
        "prod:db:studio": "dotenv -e .env.production -- prisma studio",
        "test-deploy": "pnpm build-info && pnpm prod:docker:down && pnpm docker:build && pnpm prod:docker:up",
        "test": "dotenv -e .env.local -- vitest run",
        "test:watch": "dotenv -e .env.local -- vitest",
        "deps:update": "node scripts/update-deps.js"
    },
    "dependencies": {
        "@atproto/api": "^0.20.11",
        "@aws-sdk/client-s3": "^3.1064.0",
        "@better-auth/prisma-adapter": "^1.6.15",
        "@contentauth/c2pa-node": "^0.5.5",
        "@contentauth/c2pa-web": "^0.10.0",
        "@hookform/resolvers": "^5.4.0",
        "@openrouter/sdk": "^0.12.79",
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "@radix-ui/react-dialog": "^1.1.16",
        "@radix-ui/react-dropdown-menu": "^2.1.17",
        "@radix-ui/react-label": "^2.1.9",
        "@radix-ui/react-menubar": "^1.1.17",
        "@radix-ui/react-popover": "^1.1.16",
        "@radix-ui/react-select": "^2.3.0",
        "@radix-ui/react-slot": "^1.2.5",
        "@scure/base": "^2.2.0",
        "bcryptjs": "^3.0.3",
        "better-auth": "^1.6.15",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "culori": "^4.0.2",
        "hash-wasm": "^4.12.0",
        "lucide-react": "^1.17.0",
        "next": "16.2.7",
        "next-intl": "^4.13.0",
        "next-themes": "^0.4.6",
        "pg": "^8.21.0",
        "qrcode": "^1.5.4",
        "qrcode.react": "^4.2.0",
        "rate-limiter-flexible": "^11.2.0",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "react-hook-form": "^7.78.0",
        "react-icons": "^5.6.0",
        "react-router-dom": "^7.17.0",
        "tailwind-merge": "^3.6.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/culori": "^4.0.1",
        "@types/node": "^24.13.1",
        "@types/pg": "^8.20.0",
        "@types/qrcode": "^1.5.6",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@typescript-eslint/eslint-plugin": "^8.61.0",
        "@typescript-eslint/parser": "^8.61.0",
        "autoprefixer": "^10.5.0",
        "baseline-browser-mapping": "^2.10.34",
        "dotenv": "^17.4.2",
        "dotenv-cli": "^11.0.0",
        "eslint": "^10.4.1",
        "eslint-config-next": "16.2.7",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "kysely": "0.29.2",
        "postcss": "^8.5.15",
        "prettier": "^3.8.3",
        "prisma": "^7.8.0",
        "tailwindcss": "^3.4.19",
        "tailwindcss-animate": "^1.0.7",
        "typescript": "^6.0.3",
        "vitest": "^4.1.8"
    }
}
