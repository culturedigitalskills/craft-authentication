{
    "name": "craft-authentication",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "dotenv -e .env.local -- next dev",
        "docker:up": "docker compose -f docker-compose.dev.yml --env-file .env.local up -d",
        "docker:down": "docker compose -f docker-compose.dev.yml --env-file .env.local down",
        "garage:init": "node scripts/init-garage.js .env.local craft-authentication",
        "db:studio": "dotenv -e .env.local -- prisma studio",
        "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
        "db:push": "dotenv -e .env.local -- prisma db push",
        "build": "dotenv -e .env.production -- next build",
        "start": "dotenv -e .env.production -- next start",
        "lint": "eslint .",
        "lint:fix": "pnpm lint --fix",
        "prisma:generate": "dotenv -e .env.local -- prisma generate",
        "docker:build": "docker compose --env-file .env.production build app",
        "prod:docker:up": "docker compose --env-file .env.production up -d",
        "prod:docker:down": "docker compose --env-file .env.production down",
        "prod:garage:init": "node scripts/init-garage.js .env.production craft-authentication",
        "prod:db:migrate": "dotenv -e .env.production -- prisma migrate deploy",
        "prod:db:push": "dotenv -e .env.production -- prisma db push",
        "prod:db:studio": "dotenv -e .env.production -- prisma studio"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.665.0",
        "@prisma/adapter-pg": "^7.1.0",
        "@prisma/client": "^7.1.0",
        "@radix-ui/react-slot": "^1.2.4",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^0.557.0",
        "next": "16.0.8",
        "pg": "^8.16.3",
        "react": "19.2.1",
        "react-dom": "19.2.1",
        "tailwind-merge": "^3.4.0",
        "zod": "^4.1.13"
    },
    "devDependencies": {
        "@types/node": "^20",
        "@types/pg": "^8.15.6",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@typescript-eslint/eslint-plugin": "^8.49.0",
        "@typescript-eslint/parser": "^8.49.0",
        "autoprefixer": "^10.4.22",
        "dotenv": "^17.2.3",
        "dotenv-cli": "^11.0.0",
        "eslint": "^9",
        "eslint-config-next": "16.0.8",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.4",
        "postcss": "^8.5.6",
        "prettier": "^3.7.4",
        "prisma": "^7.1.0",
        "tailwindcss": "^3.4.17",
        "tailwindcss-animate": "^1.0.7",
        "typescript": "^5"
    }
}
