generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model MediaFile {
  id           String   @id @default(uuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  bucket       String
  objectKey    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now())
  
  @@index([createdAt], name: "idx_media_files_created_at")
}

model DataRecord {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
  name        String
  description String?
  data        Json

  @@index([createdAt], name: "idx_data_records_created_at")
}
