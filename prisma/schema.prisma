generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

// Enums

enum Role {
    ADMIN
    ARTISAN
}

enum TagType {
    QR
    NFC
}

enum AttachmentType {
    HERO
    COVER
    GALLERY
    PROCESS
}

enum GroupRole {
    ADMIN
    MEMBER
}

enum OrganizationType {
    COOPERATIVE
    COLLECTIVE
    GUILD
    ASSOCIATION
    SOCIAL_ENTERPRISE
    NONPROFIT
    STUDIO
    NETWORK
    OTHER
}

enum CraftStoryStatus {
    DRAFT
    PUBLISHED
}

// Auth Models

model User {
    id            String                 @id @default(uuid())
    name          String?
    email         String                 @unique
    emailVerified Boolean                @default(false)
    password      String?
    image         String?
    role          Role                   @default(ARTISAN)
    isActive      Boolean                @default(true)
    masterKeyHash     String?                @map("master_key_hash")
    c2paAutoRenew     Boolean                @default(false) @map("c2pa_auto_renew")
    c2paCertExpiresAt DateTime?              @map("c2pa_cert_expires_at")
    createdAt         DateTime               @default(now())
    updatedAt     DateTime               @updatedAt
    accounts      Account[]
    sessions      Session[]
    artisan       Artisan?
    mediaFiles    MediaFile[]
    secrets       UserSecrets[]
    wrappedKeys   UserWrappedVaultKeys[]
    taskEvents    TaskEvent[]
}

model Account {
    id                    String    @id @default(uuid())
    accountId             String
    providerId            String
    userId                String
    user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    accessToken           String?
    refreshToken          String?
    idToken               String?
    expiresAt             DateTime?
    password              String?
    createdAt             DateTime  @default(now())
    updatedAt             DateTime  @updatedAt
    accessTokenExpiresAt  DateTime?
    refreshTokenExpiresAt DateTime?
    scope                 String?

    @@unique([providerId, accountId])
}

model Session {
    id        String   @id @default(uuid())
    expiresAt DateTime
    token     String   @unique
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    ipAddress String?
    userAgent String?
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
    id         String    @id @default(uuid())
    identifier String
    value      String
    expiresAt  DateTime
    createdAt  DateTime? @default(now())
    updatedAt  DateTime? @updatedAt
}

// Utility Models

model MediaFile {
    id               String            @id @default(uuid())
    filename         String
    originalName     String
    mimeType         String
    size             Int
    bucket           String
    objectKey        String
    uploaderId       String?
    createdAt        DateTime          @default(now())
    updatedAt        DateTime          @default(now())
    mediaAttachments MediaAttachment[]
    uploader         User?             @relation(fields: [uploaderId], references: [id], onDelete: SetNull)
    taskEvents       TaskEvent[]

    @@index([createdAt], name: "idx_media_files_created_at")
    @@index([uploaderId], name: "idx_media_files_uploader_id")
}

model DataRecord {
    id          String   @id @default(uuid())
    createdAt   DateTime @default(now())
    updatedAt   DateTime @default(now())
    name        String
    description String?
    data        Json

    @@index([createdAt], name: "idx_data_records_created_at")
}

// Groups & Artisans

model Group {
    id                 String              @id @default(uuid())
    name               String
    slug               String              @unique
    previousSlugs      String[]            @default([])
    description        String?
    website            String?
    location           String?
    organizationType   OrganizationType    @default(OTHER)
    certifications     String[]            @default([])
    isHeritageCraft    Boolean             @default(false)
    isOpenToMembers    Boolean             @default(true)
    hasTrainingProgram Boolean             @default(false)
    isActive           Boolean             @default(true)
    createdAt          DateTime            @default(now())
    updatedAt          DateTime            @updatedAt
    memberships        ArtisanGroupMembership[]

    @@index([previousSlugs], type: Gin)
}

model Artisan {
    id                String                       @id @default(uuid())
    userId            String                       @unique
    country           String?
    region            String?
    firstName         String
    lastName          String
    slug              String                       @unique
    previousSlugs     String[]                     @default([])
    bio               String?
    yearsOfExperience Int?
    learningSource    String?
    latitude          Float?
    longitude         Float?
    socialInstagram   String?                      @db.VarChar(100)
    socialFacebook    String?                      @db.VarChar(100)
    socialTwitter     String?                      @db.VarChar(100)
    socialTiktok      String?                      @db.VarChar(100)
    socialYoutube     String?                      @db.VarChar(100)
    website           String?                      @db.VarChar(255)
    hashtags          String[]                     @default([])
    createdAt         DateTime                     @default(now())
    updatedAt         DateTime                     @updatedAt
    deletedAt         DateTime?
    user              User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
    memberships       ArtisanGroupMembership[]
    craftStory        CraftStory?
    crafts            Craft[]

    @@index([previousSlugs], type: Gin)
}

model Craft {
    id               String    @id @default(uuid())
    artisanId        String
    title            String
    description      String?
    materials        String?
    technique        String?
    timeToMake       String?
    width            Float?
    height           Float?
    depth            Float?
    dimensionUnit    String?
    weight           Float?
    weightUnit       String?
    inspiration      String?
    careInstructions String?
    isPublic         Boolean   @default(false)
    isSharedLocation Boolean   @default(true)
    latitude         Float?
    longitude        Float?
    place            String?
    videos           String[]  @default([]) // YouTube IDs
    createdAt        DateTime  @default(now())
    updatedAt        DateTime  @updatedAt
    deletedAt        DateTime?
    artisan          Artisan   @relation(fields: [artisanId], references: [id], onDelete: Cascade)

    @@index([artisanId])
    @@index([isPublic])
}

model CraftStory {
    id                      String           @id @default(uuid())
    artisanId               String           @unique
    status                  CraftStoryStatus @default(DRAFT)
    lastStepReached         Int              @default(0)
    answerSelfText          String?
    answerSelfMediaId       String?
    answerCraftText         String?
    answerCraftMediaId      String?
    answerMeaningText       String?
    answerMeaningMediaId    String?
    answerBenefitsText      String?
    answerBenefitsMediaId   String?
    answerFutureText        String?
    answerFutureMediaId     String?
    answerChallengesText    String?
    answerChallengesMediaId String?
    publishedAt             DateTime?
    createdAt               DateTime         @default(now())
    updatedAt               DateTime         @updatedAt
    artisan                 Artisan          @relation(fields: [artisanId], references: [id], onDelete: Cascade)
}

model ArtisanGroupMembership {
    id         String    @id @default(uuid())
    artisanId  String
    groupId    String
    role       GroupRole @default(MEMBER)
    isPrimary  Boolean   @default(false)
    joinedDate DateTime  @default(now())
    leftDate   DateTime?
    artisan    Artisan   @relation(fields: [artisanId], references: [id], onDelete: Cascade)
    group      Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)

    @@unique([artisanId, groupId])
}

// QR Tags & Scanning

model BatchTag {
    id            String    @id @default(uuid())
    batchId       String
    itemNumber    Int
    tagCode       String    @unique
    tagType       TagType   @default(QR)
    scanCount     Int       @default(0)
    isActive      Boolean   @default(true)
    createdAt     DateTime  @default(now())
    deactivatedAt DateTime?
    scans         TagScan[]

    @@index([batchId])
}

model TagScan {
    id          String   @id @default(uuid())
    tagId       String
    scannedAt   DateTime @default(now())
    countryCode String?
    city        String?
    tag         BatchTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

    @@index([tagId])
}

// Verifiable Credentials

model VerifiableCredential {
    id                String   @id @default(uuid())
    credentialId      String   @unique
    issuerDid         String
    holderDid         String
    credentialType    String
    credentialSubject Json
    proof             Json
    issuanceDate      DateTime
    expirationDate    DateTime?
    createdAt         DateTime @default(now())
    updatedAt         DateTime @updatedAt

    @@index([holderDid])
}

// Media Attachments

model MediaAttachment {
    id             String         @id @default(uuid())
    mediaId        String
    entityType     String
    entityId       String
    attachmentType AttachmentType @default(GALLERY)
    isPrimary      Boolean        @default(false)
    isPublic       Boolean        @default(true)
    displayOrder   Int            @default(0)
    createdAt      DateTime       @default(now())
    media          MediaFile      @relation(fields: [mediaId], references: [id], onDelete: Cascade)

    @@index([entityType, entityId])
    @@index([mediaId])
}

// Vault Models

enum VaultWrapMode {
    E2E_PRF
    SSE_KMS
    RECOVERY_TOKEN
}

model UserSecrets {
    id             String   @id @default(uuid())
    userId         String   @map("user_id")
    type           String
    ciphertextData String   @map("ciphertext_data")
    createdAt      DateTime @default(now()) @map("created_at")
    updatedAt      DateTime @updatedAt @map("updated_at")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
}

model UserWrappedVaultKeys {
    id           String        @id @default(uuid())
    userId       String        @map("user_id")
    credentialId String?       @map("credential_id")
    wrapMode     VaultWrapMode @map("wrap_mode")
    wrappedKey   String        @map("wrapped_key")
    createdAt    DateTime      @default(now()) @map("created_at")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([credentialId])
}

model TaskEvent {
    id           String    @id @default(uuid())
    userId       String    @map("user_id")
    type         String    @default("image-generation")
    settings     Json
    errorMessage String?   @map("error_message")
    mediaFileId  String?   @map("media_file_id")

    createdAt    DateTime  @default(now()) @map("created_at")
    sentAt       DateTime? @map("sent_at")
    canceledAt   DateTime? @map("canceled_at")
    receivedAt   DateTime? @map("received_at")
    errorAt      DateTime? @map("error_at")

    user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
    mediaFile    MediaFile? @relation(fields: [mediaFileId], references: [id], onDelete: SetNull)

    @@index([userId])
    @@index([type])
    @@index([createdAt])
}

